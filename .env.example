# Kor Trading Agent — 시크릿 템플릿
# 이 파일을 .env로 복사한 뒤 실제 값으로 채우세요.
# .env는 절대 커밋하지 마세요 (.gitignore 처리 필수)

# ── 텔레그램 봇 (✅ 확정) ─────────────────────
# 1. @BotFather에서 봇 생성 후 토큰 발급
# 2. 봇과 대화 시작 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DART OpenAPI (✅ 확정) ────────────────────
# https://opendart.fss.or.kr/ 에서 무료 발급
DART_API_KEY=

# ── KRX data 포털 (✅ pykrx 필수) ──────────────
# data.krx.co.kr 가 데이터 조회에 로그인을 의무화함.
# https://data.krx.co.kr 에서 무료 회원가입 후 ID/PW 입력.
# 없으면 pykrx가 "LOGOUT" 응답으로 시세를 못 받음.
KRX_ID=
KRX_PW=

# ── (Phase 2) KIS Developers Open API ─────────
# 한국투자증권 https://apiportal.koreainvestment.com/
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ENV=virtual   # virtual | prod
